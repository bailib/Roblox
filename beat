function LSTabEle:LSCreateSlider(Title, default, min, max, precise, callback)
    local min = min or 1
    local max = max or 10
    local default = default or min
    local precise = precise or false

    local SliderFrame = Instance.new("Frame")
    SliderFrame.Size = UDim2.new(1, 0, 0, 60)
    SliderFrame.BackgroundTransparency = 1
    SliderFrame.Parent = TabsContainer

    local SliderLabel = Instance.new("TextLabel")
    SliderLabel.Size = UDim2.new(1, 0, 0, 20)
    SliderLabel.Position = UDim2.new(0, 0, 0, 5)
    SliderLabel.BackgroundTransparency = 1
    SliderLabel.Text = Title
    SliderLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    SliderLabel.Font = 9
    SliderLabel.TextSize = 14
    SliderLabel.Parent = SliderFrame

    local SliderBar = Instance.new("Frame")
    SliderBar.Size = UDim2.new(1, 0, 0, 5)
    SliderBar.Position = UDim2.new(0, 0, 0, 25)
    SliderBar.BackgroundTransparency = 1
    SliderBar.Parent = SliderFrame

    local SliderFill = Instance.new("Frame")
    SliderFill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
    SliderFill.BackgroundTransparency = 1
    SliderFill.BackgroundColor3 = Color3.fromRGB(0, 123, 255)
    SliderFill.Parent = SliderBar

    local SliderValue = Instance.new("TextBox")
    SliderValue.Size = UDim2.new(1, 0, 0, 20)
    SliderValue.Position = UDim2.new(0, 0, 0, 35)
    SliderValue.BackgroundTransparency = 1
    SliderValue.Text = tostring(default)
    SliderValue.TextColor3 = Color3.fromRGB(255, 255, 255)
    SliderValue.Font = 9
    SliderValue.TextSize = 14
    SliderValue.Parent = SliderFrame

    local function updateValue()
        local mouseX = game.Players.LocalPlayer:GetMouse().X
        local ratio = (mouseX - SliderBar.AbsolutePosition.X) / SliderBar.AbsoluteSize.X
        local newValue = min + ratio * (max - min)
        if precise then
            newValue = math.min(max, math.max(min, math.floor(newValue * 10 + 0.5) / 10))
        else
            newValue = math.min(max, math.max(min, math.floor(newValue + 0.5)))
        end
        SliderFill.Size = UDim2.new((newValue - min) / (max - min), 0, 1, 0)
        SliderValue.Text = tostring(newValue)
        callback(newValue)
    end

    SliderBar.MouseButton1Down:Connect(function()
        local function onMove()
            updateValue()
        end
        mouse.Move:Connect(onMove)
        mouse.Button1Up:Connect(function()
            mouse.Move:Disconnect(onMove)
        end)
    end)
end

