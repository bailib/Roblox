function TabElements:Dropdown(Title, Options, Cally)
    local DropdownFrame = Instance.new("Frame")
    DropdownFrame.Size = UDim2.new(1, 0, 0, 25)
    DropdownFrame.BackgroundColor3 = Color3.fromHex("1D1D27")
    DropdownFrame.BorderSizePixel = 0
    DropdownFrame.Parent = Tab
    Instance.new("UICorner", DropdownFrame).CornerRadius = UDim.new(0, 8)

    local TextLabel = Instance.new("TextLabel")
    TextLabel.Size = UDim2.new(0, 200, 1, 0)
    TextLabel.BackgroundTransparency = 1
    TextLabel.TextColor3 = Color3.fromHex("7A7A84")
    TextLabel.Text = Title
    TextLabel.Font = 9
    TextLabel.TextScaled = true
    TextLabel.TextXAlignment = 0
    TextLabel.Position = UDim2.new(0, 8, 0, 0)
    TextLabel.Parent = DropdownFrame

    local ExpandText = Instance.new("TextLabel")
    ExpandText.Size = UDim2.new(0, 20, 1, 0)
    ExpandText.BackgroundTransparency = 1
    ExpandText.TextColor3 = Color3.fromHex("7A7A84")
    ExpandText.Text = "+"
    ExpandText.Font = 9
    ExpandText.TextScaled = true
    ExpandText.TextXAlignment = 1
    ExpandText.Position = UDim2.new(1, -25, 0, 0)
    ExpandText.Parent = DropdownFrame

    local DropdownList = Instance.new("Frame")
    DropdownList.Size = UDim2.new(1, -20, 0, 0)
    DropdownList.BackgroundColor3 = Color3.fromHex("1D1D27")
    DropdownList.BorderSizePixel = 0
    DropdownList.Position = UDim2.new(0, 1, 1, 0)
    DropdownList.Visible = false
    DropdownList.Parent = DropdownFrame
    Instance.new("UICorner", DropdownList).CornerRadius = UDim.new(0, 8)

    for _, Option in ipairs(Options) do
        local OptionButton = Instance.new("TextButton")
        OptionButton.Size = UDim2.new(1, 0, 0, 25)
        OptionButton.BackgroundColor3 = Color3.fromHex("1D1D27")
        OptionButton.BorderSizePixel = 0
        OptionButton.Text = Option
        OptionButton.TextColor3 = Color3.fromHex("7A7A84")
        OptionButton.Font = 9
        OptionButton.TextScaled = true
        OptionButton.TextXAlignment = 0
        OptionButton.Position = UDim2.new(0, 8, 0, 0)
        OptionButton.Parent = DropdownList
        Instance.new("UICorner", OptionButton).CornerRadius = UDim.new(0, 8)
        OptionButton.MouseButton1Click:Connect(function()
            pcall(Cally, Option)
            DropdownList.Visible = false
            ExpandText.Text = "+"
        end)
    end

    ExpandText.MouseButton1Click:Connect(function()
        if DropdownList.Visible then
            DropdownList.Visible = false
            ExpandText.Text = "+"
        else
            DropdownList.Visible = true
            ExpandText.Text = "-"
        end
    end)
end

