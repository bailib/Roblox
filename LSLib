function TabElements:Combobox(Title, Options, DefaultIndex, Cally)
    local ComboboxFrame = Instance.new("Frame")
    ComboboxFrame.Size = UDim2.new(1, 0, 0, 25)
    ComboboxFrame.BackgroundColor3 = Color3.fromHex("1D1D27")
    ComboboxFrame.BorderSizePixel = 0
    ComboboxFrame.Parent = Tab
    Instance.new("UICorner", ComboboxFrame).CornerRadius = UDim.new(0, 8)

    local Label = Instance.new("TextLabel")
    Label.Size = UDim2.new(1, 0, 0, 25)
    Label.BackgroundTransparency = 1
    Label.TextColor3 = Color3.fromHex("7A7A84")
    Label.Text = Title
    Label.Font = 9
    Label.TextScaled = true
    Label.TextXAlignment = 0
    Label.Position = UDim2.new(0, 8, 0, 0)
    Label.Parent = ComboboxFrame

    local Dropdown = Instance.new("TextButton")
    Dropdown.Size = UDim2.new(1, 0, 1, 0)
    Dropdown.BackgroundColor3 = Color3.fromHex("1D1D27")
    Dropdown.BorderSizePixel = 0
    Dropdown.Font = 9
    Dropdown.TextColor3 = Color3.fromHex("7A7A84")
    Dropdown.Text = Options[DefaultIndex] or ""
    Dropdown.TextXAlignment = 0
    Dropdown.Position = UDim2.new(0, 8, 0, 0)
    Dropdown.Parent = ComboboxFrame

    local function updateText()
        Dropdown.Text = Options[DefaultIndex] or ""
    end

    Dropdown.MouseButton1Click:Connect(function()
        local Open = not Dropdown.Open
        Dropdown.Open = Open
        for _, Button in pairs(ComboboxFrame:GetChildren()) do
            if Button:IsA("TextButton") and Button.Name ~= "DropdownButton" then
                Button:Destroy()
            end
        end
        if Open then
            for i, v in pairs(Options) do
                local Button = Instance.new("TextButton")
                Button.Size = UDim2.new(1, 0, 0, 25)
                Button.BackgroundColor3 = Color3.fromHex("1D1D27")
                Button.BorderSizePixel = 0
                Button.Font = 9
                Button.TextColor3 = Color3.fromHex("7A7A84")
                Button.Text = v
                Button.TextXAlignment = 0
                Button.Position = UDim2.new(0, 0, i - 1, 30)
                Button.Parent = ComboboxFrame
                Button.MouseButton1Click:Connect(function()
                    DefaultIndex = i
                    updateText()
                    Dropdown.Open = false
                    pcall(Cally, i)
                end)
            end
        end
    end)
end

