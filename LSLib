function TabElements:Slider(Title, Min, Max, Default, Cally)
    local SliderFrame = Instance.new("Frame")
    SliderFrame.Size = UDim2.new(1, 0, 0, 50)
    SliderFrame.BackgroundColor3 = Color3.fromHex("1D1D27")
    SliderFrame.BorderSizePixel = 0
    SliderFrame.Parent = Tab
    Instance.new("UICorner", SliderFrame).CornerRadius = UDim.new(0, 8)

    local Label = Instance.new("TextLabel")
    Label.Size = UDim2.new(0, 100, 1, 0)
    Label.BackgroundTransparency = 1
    Label.TextColor3 = Color3.fromHex("7A7A84")
    Label.Text = Title
    Label.Font = 9
    Label.TextScaled = true
    Label.TextXAlignment = 0
    Label.Position = UDim2.new(0, 8, 0, 0)
    Label.Parent = SliderFrame

    local TextBox = Instance.new("TextBox")
    TextBox.Size = UDim2.new(0, 50, 1, 0)
    TextBox.Font = 9
    TextBox.TextColor3 = Color3.fromHex("7A7A84")
    TextBox.BackgroundColor3 = Color3.fromHex("1D1D27")
    TextBox.BorderSizePixel = 0
    TextBox.Position = UDim2.new(0, 108, 0, 0)
    TextBox.Text = "LSTM Archive Textbox"
    TextBox.Parent = SliderFrame

    local SliderBar = Instance.new("Frame")
    SliderBar.Size = UDim2.new(1, -160, 0, 20)
    SliderBar.BackgroundColor3 = Color3.fromHex("7A7A84")
    SliderBar.BorderSizePixel = 0
    SliderBar.Position = UDim2.new(0, 8, 0, 25)
    SliderBar.Parent = SliderFrame
    Instance.new("UICorner", SliderBar).CornerRadius = UDim.new(0, 8)

    local SliderButton = Instance.new("Frame")
    SliderButton.Size = UDim2.new(0, 20, 1, 0)
    SliderButton.BackgroundColor3 = Color3.fromHex("AFA1FD")
    SliderButton.BorderSizePixel = 0
    SliderButton.Position = UDim2.new((Default - Min) / (Max - Min), 0, 0, 0)
    SliderButton.Parent = SliderBar
    Instance.new("UICorner", SliderButton).CornerRadius = UDim.new(0, 8)

    local SliderValue = Instance.new("TextLabel")
    SliderValue.Size = UDim2.new(1, -160, 0, 25)
    SliderValue.BackgroundTransparency = 1
    SliderValue.TextColor3 = Color3.fromHex("7A7A84")
    SliderValue.Text = tostring(Default)
    SliderValue.Font = 9
    SliderValue.TextScaled = true
    SliderValue.TextXAlignment = 0
    SliderValue.Position = UDim2.new(0, 8, 1, 0)
    SliderValue.Parent = SliderFrame

    SliderButton.MouseButton1Down:Connect(function()
        local StartX = SliderButton.Position.X.Scale
        local function updateSlider()
            local X = (Mouse.X - SliderBar.AbsolutePosition.X) / SliderBar.AbsoluteSize.X
            X = math.clamp(X, 0, 1)
            SliderButton.Position = UDim2.new(X, 0, 0, 0)
            local Value = X * (Max - Min) + Min
            SliderValue.Text = tostring(math.floor(Value))
            pcall(Cally, Value)
        end
        updateSlider()
        mouse.Move:Connect(updateSlider)
        mouse.Button1Up:Wait()
        mouse.Move:Disconnect()
    end)
end

